<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/btnBackFavorites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:padding="4dp" />

        <TextView
            android:id="@+id/txtFavoritesTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Favorites"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#222222" />

        <LinearLayout
            android:id="@+id/cardFavorite1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FFFFFF">

            <ImageView
                android:id="@+id/imgFavorite1"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:src="@drawable/spot"
                android:contentDescription="Favorite Court" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtFavorite1Name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elite Tennis Club"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/txtFavorite1Info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="⭐ 4.5   📍 2.3 km"
                    android:textSize="15sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/txtFavorite1Price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="$20/hr"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardFavorite2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FFFFFF">

            <ImageView
                android:id="@+id/imgFavorite2"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:src="@drawable/spot"
                android:contentDescription="Favorite Court" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtFavorite2Name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Central Soccer Field"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/txtFavorite2Info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="⭐ 4.7   📍 4.1 km"
                    android:textSize="15sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/txtFavorite2Price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="$30/hr"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>